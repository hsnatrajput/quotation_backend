<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Quotation <%= quotation.proposalId %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap');
    
    body { font-family: system-ui, -apple-system, sans-serif; }
    .serif { font-family: 'Playfair Display', serif; }
    
    html { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    @page { margin: 15mm; size: A4; }
    
    .section { page-break-inside: avoid; margin-bottom: 40px; }
    .dark-bg { background-color: #374151 !important; color: white; }
    .page-break { page-break-before: always; }
  </style>
</head>
<body class="bg-white text-gray-900">

  <!-- Customer Greeting (Dark Section) -->
  <div class="section dark-bg py-20 px-12">
    <div class="max-w-5xl mx-auto">
      <h1 class="serif text-6xl font-bold text-white leading-tight">
        Dear <%= quotation.customerName || 'Valued Customer' %>,
      </h1>
      <p class="mt-10 text-xl text-gray-200 leading-relaxed">
        Thank you for choosing Air Utilities to power your project at <%= quotation.siteAddress %>.
      </p>
      <p class="mt-6 text-xl text-gray-200 leading-relaxed">
        We truly appreciate the trust you have placed in us...
      </p>
    </div>
  </div>

  <!-- Quotation Summary -->
  <div class="section py-16 px-12">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-4xl font-bold text-center mb-12">QUOTATION SUMMARY</h2>
      <div class="bg-white border border-gray-200 rounded-2xl p-10 shadow">
        <p class="text-2xl"><strong>Total Amount:</strong> £<%= quotation.totalAmount?.toFixed(2) || '0.00' %></p>
        <!-- Add more summary fields as needed -->
      </div>
    </div>
  </div>

  <!-- Add other sections: Scope Table, Tender Inclusions, Air Source Heat Pumps, Non-Contestable, Delivery Standards, Assumptions, etc. -->

  <!-- Delivery Standards (Static) -->
  <div class="section py-16 px-12 page-break">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-4xl font-bold text-center mb-10">DELIVERY STANDARDS</h2>
      <div class="space-y-8">
        <!-- Paste your static delivery standards cards here (same as DeliveryStandards.js) -->
        <div class="bg-gray-50 p-8 rounded-2xl">
          <h3 class="font-semibold text-xl">Design Period</h3>
          <p class="mt-3 text-gray-700">AU require 8-10 weeks from receipt of the required documentation and upfront payment to mobilisation to site.</p>
        </div>
        <!-- Repeat for all other standards -->
      </div>
    </div>
  </div>

  <div class="text-center text-sm text-gray-500 py-10">
    Air Utilities • 143 Hamilton Road, Manchester, M13 0PL
  </div>

</body>
</html>